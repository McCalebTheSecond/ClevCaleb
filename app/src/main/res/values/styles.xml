<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="CalcButton" parent="Widget.Material3.Button.TextButton">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_margin">4dp</item>
        <item name="android:textSize">24sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="backgroundTint">@color/surface</item>
        <item name="cornerRadius">16dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <style name="CalcButton.Operator">
        <item name="android:textColor">@color/text_primary</item>
        <item name="backgroundTint">@color/blue_700</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="CalcButton.Accent">
        <item name="backgroundTint">@color/blue_500</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>
